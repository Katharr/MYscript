{
  "window_title": "梦幻西游",
  "input_backend": "sendinput",
  "window_offset": [0, 0],
  "hotkey_toggle": "F5",
  "humanize": {
    "speed": 2.0,
    "snipe_speed": 5.0,
    "click_radius": 4,
    "px_per_step": 12,
    "interval_jitter": 0.4,
    "idle_chance": 0.0,
    "idle_min_sec": 1.5,
    "idle_max_sec": 5.0
  },
  "hotkeys": {
    "close_panel": ["esc"],
    "open_bag": ["alt", "e"],
    "open_task": ["alt", "q"],
    "open_activity": []
  },
  "tasks": {
    "sniper": {
      "dry_run": true,
      "loop": {
        "refresh_interval_sec": 0.2,
        "shelf_load_wait_sec": 1.2,
        "shelf_load_min_sec": 0.15,
        "match_threshold": 0.85,
        "after_buy_cooldown_sec": 2.0
      },
      "regions": {
        "listing": [120, 200, 600, 360],
        "category_button": [40, 240, 96, 36],
        "product_entry": [180, 300, 160, 40],
        "buy_button": [760, 480, 90, 36],
        "confirm_button": [430, 360, 100, 40]
      },
      "watchlist": [
        { "name": "wujibie_xianglian", "template": "templates/wujibie_xianglian.png", "max_price": null }
      ]
    },
    "treasure_map": {
      "dry_run": true,
      "skip_collect": false,
      "loop": {
        "time_limit_min": 30,
        "match_threshold": 0.85,
        "tick_interval_sec": 0.6,
        "still_min_sec": 0.3,
        "still_wait_sec": 2.0,
        "collect_idle_sec": 4.0,
        "activity_timeout_sec": 30,
        "dialog_timeout_sec": 30,
        "collect_timeout_sec": 600,
        "dig_timeout_sec": 120,
        "scroll_step": -3,
        "scroll_max_tries": 8,
        "max_stuck_recover": 3
      },
      "regions": {
        "scene": [0, 0, 1024, 768],
        "activity_button": [900, 120, 60, 40],
        "activity_list": [600, 200, 360, 420],
        "bag_list": [560, 220, 380, 360],
        "blank_spot": [200, 150, 20, 20]
      },
      "templates": {
        "flag_treasure_entry": "templates/tm_flag_treasure_entry.png",
        "flag_tingting": "templates/tm_flag_tingting.png",
        "flag_dialog": null,
        "flag_battle": "templates/tm_flag_battle.png",
        "flag_next_map": "templates/tm_flag_next_map.png",
        "treasure_item": "templates/tm_treasure_item.png"
      }
    }
  }
}
